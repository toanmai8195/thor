<!--
=============================================================================
CLICKHOUSE USERS CONFIGURATION
=============================================================================
File này định nghĩa users và permissions cho ClickHouse.

Trong production, bạn cần:
- Tạo users riêng cho mỗi service
- Set passwords mạnh
- Giới hạn IP access
- Định nghĩa quotas và resource limits
=============================================================================
-->
<clickhouse>
    <users>
        <!--
        ==========================================================================
        DEFAULT USER
        User mặc định để development và testing
        ==========================================================================
        -->
        <default>
            <!-- Không cần password cho development -->
            <password></password>

            <!-- Cho phép access từ mọi IP -->
            <networks>
                <ip>::/0</ip>
            </networks>

            <!-- Full access đến tất cả databases -->
            <access_management>1</access_management>

            <!--
            Profile: Tập hợp các settings
            - max_memory_usage: RAM tối đa cho 1 query
            - max_execution_time: Timeout cho queries
            -->
            <profile>default</profile>

            <!-- Quota: Giới hạn resources theo thời gian -->
            <quota>default</quota>
        </default>

        <!--
        ==========================================================================
        TRACKING USER
        User chuyên dụng cho tracking-ingestor service
        Có quyền INSERT vào tracking database
        ==========================================================================
        -->
        <tracking>
            <!-- Hash của password "tracking123" -->
            <password_sha256_hex>a665a45920422f9d417e4867efdc4fb8a04a1f3fff1fa07e998e86f7f7a27ae3</password_sha256_hex>

            <networks>
                <ip>::/0</ip>
            </networks>

            <profile>default</profile>
            <quota>default</quota>

            <!-- Chỉ có quyền INSERT và SELECT, không có DDL -->
            <allow_ddl>0</allow_ddl>
        </tracking>

        <!--
        ==========================================================================
        ANALYTICS USER
        User cho analytics queries và dbt
        Có quyền SELECT và CREATE VIEW
        ==========================================================================
        -->
        <analytics>
            <password_sha256_hex>a665a45920422f9d417e4867efdc4fb8a04a1f3fff1fa07e998e86f7f7a27ae3</password_sha256_hex>

            <networks>
                <ip>::/0</ip>
            </networks>

            <profile>analytics</profile>
            <quota>analytics</quota>
        </analytics>
    </users>

    <!--
    ==========================================================================
    PROFILES
    Định nghĩa các preset settings
    ==========================================================================
    -->
    <profiles>
        <default>
            <!-- Memory limit: 10GB -->
            <max_memory_usage>10737418240</max_memory_usage>

            <!-- Query timeout: 5 phút -->
            <max_execution_time>300</max_execution_time>

            <!-- Số threads tối đa -->
            <max_threads>8</max_threads>

            <!-- Load balancing cho distributed queries -->
            <load_balancing>random</load_balancing>

            <!-- Cho phép introspection functions (stacktrace, addressToLine) để debug -->
            <allow_introspection_functions>1</allow_introspection_functions>
        </default>

        <analytics>
            <!-- Analytics queries có thể cần nhiều memory hơn -->
            <max_memory_usage>21474836480</max_memory_usage>

            <!-- Timeout dài hơn cho complex queries -->
            <max_execution_time>600</max_execution_time>

            <max_threads>16</max_threads>

            <!--
            Readonly mode:
            0 = full access
            1 = chỉ SELECT
            2 = SELECT và thay đổi settings
            -->
            <readonly>0</readonly>
        </analytics>
    </profiles>

    <!--
    ==========================================================================
    QUOTAS
    Giới hạn resources theo thời gian
    Hữu ích để prevent abuse và ensure fair usage
    ==========================================================================
    -->
    <quotas>
        <default>
            <interval>
                <!-- Quota interval: 1 giờ -->
                <duration>3600</duration>

                <!-- Max queries per hour -->
                <queries>100000</queries>

                <!-- Max rows read per hour -->
                <read_rows>10000000000</read_rows>

                <!-- Max bytes read per hour -->
                <result_rows>10000000000</result_rows>
            </interval>
        </default>

        <analytics>
            <interval>
                <duration>3600</duration>
                <queries>10000</queries>
                <read_rows>100000000000</read_rows>
                <result_rows>100000000000</result_rows>
            </interval>
        </analytics>
    </quotas>
</clickhouse>
