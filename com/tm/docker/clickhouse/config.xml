<!--
=============================================================================
CLICKHOUSE SERVER CONFIGURATION
=============================================================================
File này chứa custom configurations cho ClickHouse server.

Các settings quan trọng:
- Kafka integration settings
- Query performance tuning
- Memory limits
- Logging configuration
=============================================================================
-->
<clickhouse>
    <!--
    ==========================================================================
    LOGGING
    Log level: trace, debug, information, warning, error
    ==========================================================================
    -->
    <logger>
        <level>information</level>
        <console>1</console>
    </logger>

    <!--
    ==========================================================================
    KAFKA SETTINGS
    Cấu hình kết nối đến Kafka cluster cho Kafka Engine tables

    Kafka Engine cho phép ClickHouse:
    - Subscribe vào Kafka topics
    - Tự động consume messages
    - Insert data vào tables thông qua Materialized Views
    ==========================================================================
    -->
    <kafka>
        <!-- Kafka broker address (trong docker network) -->
        <broker_list>kafka:29092</broker_list>

        <!-- Consumer settings -->
        <!-- auto.offset.reset: earliest = đọc từ đầu, latest = chỉ đọc messages mới -->
        <auto_offset_reset>earliest</auto_offset_reset>

        <!-- Số messages tối đa consume trong 1 poll -->
        <max_poll_records>10000</max_poll_records>

        <!-- Timeout cho poll (ms) -->
        <poll_timeout_ms>1000</poll_timeout_ms>

        <!-- Consumer group prefix -->
        <group_name>clickhouse</group_name>
    </kafka>

    <!--
    ==========================================================================
    QUERY SETTINGS
    Tối ưu performance cho analytics queries
    ==========================================================================
    -->
    <!-- Số threads cho SELECT queries -->
    <max_threads>8</max_threads>

    <!-- Memory limit cho single query (10GB) -->
    <max_memory_usage>10737418240</max_memory_usage>

    <!-- Cho phép introspection functions (để debug) -->
    <allow_introspection_functions>1</allow_introspection_functions>

    <!--
    ==========================================================================
    MERGE TREE SETTINGS
    MergeTree là storage engine mặc định của ClickHouse

    Cách hoạt động:
    1. Data được insert vào parts nhỏ
    2. Background merges gộp parts thành parts lớn hơn
    3. Merging cũng deduplicates và optimizes data
    ==========================================================================
    -->
    <merge_tree>
        <!-- Số parts tối đa trước khi delay inserts -->
        <parts_to_delay_insert>150</parts_to_delay_insert>

        <!-- Số parts tối đa trước khi throw exception -->
        <parts_to_throw_insert>300</parts_to_throw_insert>

        <!-- Background pool size cho merges -->
        <background_pool_size>16</background_pool_size>
    </merge_tree>

    <!--
    ==========================================================================
    COMPRESSION
    ClickHouse compress data để tiết kiệm storage và tăng query speed

    Algorithms:
    - LZ4: Fast compression/decompression, moderate ratio
    - ZSTD: Better ratio, slower than LZ4
    ==========================================================================
    -->
    <compression>
        <case>
            <!-- Với data nhỏ hơn 10KB, dùng LZ4 (nhanh) -->
            <min_part_size>0</min_part_size>
            <min_part_size_ratio>0</min_part_size_ratio>
            <method>lz4</method>
        </case>
        <case>
            <!-- Với data lớn hơn 10GB, dùng ZSTD (nén tốt hơn) -->
            <min_part_size>10737418240</min_part_size>
            <min_part_size_ratio>0.01</min_part_size_ratio>
            <method>zstd</method>
            <level>3</level>
        </case>
    </compression>

    <!--
    ==========================================================================
    DISTRIBUTED TABLES
    Settings cho distributed queries (khi có multiple shards)
    ==========================================================================
    -->
    <distributed_ddl>
        <path>/clickhouse/task_queue/ddl</path>
    </distributed_ddl>
</clickhouse>
